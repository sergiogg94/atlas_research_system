# Database settings
POSTGRES_USER=...
POSTGRES_PASSWORD=...
POSTGRES_DB=atlas_research_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE

# Redis settings
REDIS_URL=redis://redis:6379

# LLM provider
llm_provider=ollama

# Ollama settings (if using Ollama as the LLM provider)
ollama_base_url=http://localhost:11434
ollama_model=qwen2.5:7b